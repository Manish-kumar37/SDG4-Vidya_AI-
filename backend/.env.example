# ---- Choose ONE provider below ----

# Option A (recommended for IBM SkillsBuild): IBM watsonx.ai — Granite models
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# Option B (fallback / easiest to test): Groq (free tier, fast, OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.3-70b-versatile

# Which provider to use: "watsonx" or "groq"
LLM_PROVIDER=groq

# Comma-separated list of extra frontend origins allowed to call this API
# (localhost:3000 and vidya-ai.vercel.app are already allowed by default)
ALLOWED_ORIGINS=

# Free Unsplash API key, powers the Notebook feature's image search.
# Get one at https://unsplash.com/developers (free, "Demo" app tier is enough)
UNSPLASH_ACCESS_KEY=
